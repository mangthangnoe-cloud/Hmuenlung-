{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile information and settings",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "profilePic": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "theme": { "type": "string", "enum": ["light", "dark"] },
        "notificationsEnabled": { "type": "boolean" },
        "createdAt": { "type": "number" }
      },
      "required": ["uid", "name", "email", "role"]
    },
    "Post": {
      "title": "Post",
      "description": "A post created by an admin",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "authorPic": { "type": "string" },
        "text": { "type": "string" },
        "imageUrl": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "likesCount": { "type": "number" },
        "commentsCount": { "type": "number" },
        "createdAt": { "type": "number" }
      },
      "required": ["authorId", "text", "createdAt"]
    },
    "Comment": {
      "title": "Comment",
      "description": "A comment on a post",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "postId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userPic": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["postId", "userId", "text", "createdAt"]
    },
    "Like": {
      "title": "Like",
      "description": "A like on a post",
      "type": "object",
      "properties": {
        "postId": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["postId", "userId"]
    },
    "SavedPost": {
      "title": "SavedPost",
      "description": "A post saved by a user",
      "type": "object",
      "properties": {
        "postId": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["postId", "userId"]
    },
    "Activity": {
      "title": "Activity",
      "description": "User activity log",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["like", "comment", "post", "save"] },
        "targetId": { "type": "string" },
        "targetText": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["userId", "type", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile data"
    },
    "/posts/{postId}": {
      "schema": "Post",
      "description": "Posts created by admins"
    },
    "/posts/{postId}/comments/{commentId}": {
      "schema": "Comment",
      "description": "Comments on a post"
    },
    "/posts/{postId}/likes/{userId}": {
      "schema": "Like",
      "description": "Likes on a post"
    },
    "/users/{userId}/savedPosts/{postId}": {
      "schema": "SavedPost",
      "description": "Posts saved by a user"
    },
    "/users/{userId}/activity/{activityId}": {
      "schema": "Activity",
      "description": "User activity history"
    }
  }
}
